{
	"name": "shortestpath-setup",
	"displayName": "%displayName%",
	"description": "%description%",
	"version": "0.1.0",
	"publisher": "shortestpath",
	"engines": {
		"vscode": "^1.129.0"
	},
	"categories": ["Other"],
	"activationEvents": ["*", "onCommand:shortestpath.setupEnvironment"],
	"main": "./out/extension.js",
	"scripts": {
		"compile": "node ../../node_modules/typescript/bin/tsc -p ./",
		"vscode:prepublish": "npm run compile"
	},
	"contributes": {
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"shortestpath.setup.completed": {
					"type": "boolean",
					"default": false,
					"scope": "window",
					"description": "%configuration.completed%"
				},
				"shortestpath.setup.pending": {
					"type": "object",
					"default": {},
					"scope": "window",
					"description": "%configuration.pending%"
				}
			}
		},
		"commands": [
			{
				"command": "shortestpath.setupEnvironment",
				"title": "%command.configure%"
			},
			{
				"command": "shortestpath.rerunFirstRunSetup",
				"title": "%command.rerunFirstRun%"
			}
		]
	}
}
